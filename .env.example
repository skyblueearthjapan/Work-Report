# VPS版アプリの環境変数（.env にコピーして値を設定。.env はコミット禁止）
PORT=5174

# --- Gemini（音声文字起こし・処置整形・銘板OCR） ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Google 連携（Option A: 会社「作業報告書」GAS へ委譲） ---
# GAS Web アプリの /exec URL（doPost API）
GAS_API_URL=https://script.google.com/macros/s/AKfycbyYcfCrvQdWIx_z8KtFUgmvygk_n9TJP91ZZmltf7e8wM1cRBJCw4N1xKeWuSfVtlad/exec
# GAS メニュー「VPS連携 APIトークンを発行/表示」で発行したトークン
GAS_API_TOKEN=
# 設定画面「保管フォルダを開く」リンク（任意・共有フォルダのURL）
DRIVE_FOLDER_URL=

# --- Google ログイン（組織ドメイン限定） ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ALLOWED_DOMAIN=lineworks-local.info
SESSION_SECRET=
# 公開URL（OAuthリダイレクトに使用）
PUBLIC_ORIGIN=https://lineworks.tailaa1b31.ts.net
