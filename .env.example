# VPS版アプリの環境変数（.env にコピーして値を設定。.env はコミット禁止）
PORT=5174

# --- Gemini（音声文字起こし・処置整形・銘板OCR） ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Google サービスアカウント（Drive保管・外部マスターSheets読取・Gmail API送信） ---
# サービスアカウントJSONのパス（コンテナ内 /app/data 配下に置く）
GOOGLE_APPLICATION_CREDENTIALS=/app/data/service-account.json
# Drive 親フォルダID（総務部と共有するフォルダ）
DRIVE_ROOT_FOLDER_ID=
# 外部マスター（全従業員作業日報）のスプレッドシートID
MASTER_SPREADSHEET_ID=1iu5HoaknlW1W1HheeYv0jqcRq-aY0SyEE2seQd2pHkQ
# Gmail API 送信の差出人（ドメイン全体委任で impersonate するユーザー）
MAIL_SENDER=

# --- Google ログイン（組織ドメイン限定） ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ALLOWED_DOMAIN=lineworks-local.info
SESSION_SECRET=
# 公開URL（OAuthリダイレクトに使用）
PUBLIC_ORIGIN=https://lineworks.tailaa1b31.ts.net
